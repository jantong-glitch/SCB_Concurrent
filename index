var cur=-1;
function sel(i){cur=i;document.querySelectorAll(".scbar button").forEach(function(b,j){b.setAttribute("aria-pressed",j===i?"true":"false");});
 var c=document.getElementById("sccard");
 if(i<0){c.style.display="none";return;}
 var s=SC[i];c.style.display="block";
 c.innerHTML="<b>"+s.id+"</b> <span class='st'>["+(s.tag==="ok"?T("已確認","Confirmed"):s.tag==="tbc"?T("待拍板","TBC"):"GAP")+"]</span><br><b>"+T("起點:","Start: ")+"</b>"+T(s.st[0],s.st[1])+" <b>"+T("發生:","Event: ")+"</b>"+T(s.ev[0],s.ev[1])+"<br><b>"+T("預期:","Expected: ")+"</b>"+T(s.ex[0],s.ex[1]);}
SC.forEach(function(s,i){var bar=document.querySelector('.scbar[data-g="'+s.g+'"]');
 var b=document.createElement("button");b.textContent=s.id;if(s.gap)b.className="gapb";
 b.onclick=function(){sel(i);s.run();};bar.appendChild(b);});
