 SC.forEach(function(s){var tr=document.createElement("tr");
 var cls=s.tag==="ok"?"":"y";
 tr.innerHTML="<td><b>"+s.id+"</b></td><td>"+T(s.st[0],s.st[1])+"</td><td>"+T(s.ev[0],s.ev[1])+"</td><td class='"+cls+"'>"+T(s.ex[0],s.ex[1])+"</td><td>"+(s.tag==="ok"?"<span class='tag ok'>"+T("已確認","Confirmed")+"</span>":s.tag==="tbc"?"<span class='tag tbc'>"+T("待拍板","TBC")+"</span>":"<span class='tag gap'>GAP</span>")+"</td>";
 tb.appendChild(tr);});}
