function money(n){return "$"+n.toLocaleString();}
function modal(type,tiz,tie,msz,mse){var m=document.getElementById("mdl");m.className="mdl "+type;
 document.getElementById("m-ti").textContent=T(tiz,tie);
 document.getElementById("m-ms").textContent=T(msz,mse);
 document.getElementById("mask").classList.add("show");}
document.getElementById("m-ok").onclick=function(){document.getElementById("mask").classList.remove("show");};
document.addEventListener("change",function(e){var t=e.target;
 if(t&&t.matches&&t.matches(".pill input")&&t.name!=="q1")render();});
function render(){
 var box=document.getElementById("cards");box.innerHTML="";
 st.cards.forEach(function(c,i){
  var d=document.createElement("div");d.className="pol"+(c.manual?"":" sysp");
  var forced=(st.declare==="no"&&!c.manual);if(forced)c.sel=true;
  d.innerHTML='<input type="checkbox" '+(c.sel?"checked":"")+(forced?" disabled":"")+'><div><span class="nm">'+c.nm+'</span><br>'+T(c.pz,c.pe)+T("(總保費連徵費:HKD ","(Total premium w/ levy: HKD ")+c.amt.toLocaleString()+")<br>"+T("狀態:進行中","Status: In Progress")+'</div><span class="ref">'+(c.manual?T("手動加入","Manual"):"ref:1d675"+(600+c.id)+T(" · 系統偵測"," · Detected"))+'</span>'+(c.manual?'<button class="del" type="button">'+T("刪除","Delete")+'</button>':"");
  d.querySelector("input").onchange=function(e){c.sel=e.target.checked;render();};
  if(c.manual)d.querySelector(".del").onclick=function(){st.cards.splice(i,1);render();};
  box.appendChild(d);});
 var rp=120000,sp=0;st.cards.forEach(function(c){if(c.sel){if(c.t==="rp")rp+=c.amt;else sp+=c.amt;}});
 document.getElementById("trp").textContent=money(rp);document.getElementById("tsp").textContent=money(sp);
 var yes=st.declare==="yes",multi=detected()>1;
 document.getElementById("p-yes").classList.toggle("on",yes);
 document.getElementById("p-no").classList.toggle("on",!yes);
 document.querySelector("#p-yes input").checked=yes;
 document.querySelector("#p-no input").checked=!yes;
 var anyYes=yes&&detected()>0,partial=anyYes&&!sysAll();
 document.getElementById("q-reason").style.display=anyYes?"block":"none";
 document.getElementById("q-rmk1").style.display=partial?"block":"none";
 document.getElementById("q-rmk2").style.display=(!yes&&detected()>1)?"block":"none";
 ["rreason","rmk1","rmk2"].forEach(function(nm){var o=document.querySelector('input[name="'+nm+'"].oth');
  var w=document.getElementById("w-"+(nm==="rreason"?"reason":nm));
  w.style.display=(o&&o.checked)?"block":"none";});
 document.querySelectorAll(".pill").forEach(function(l){var i=l.querySelector("input");if(i&&i.name!=="q1")l.classList.toggle("on",i.checked);});
}
var lastLog=["",""];
function log(z,e){lastLog=[z,e===undefined?z:e];document.getElementById("evlog").textContent=T(lastLog[0],lastLog[1]);}
function reason(n,v){var r=document.querySelectorAll('input[name="'+n+'"]');r.forEach(function(x){x.checked=false;});if(v&&r[0])r[0].checked=true;}
function filled(n){var r=document.querySelector('input[name="'+n+'"]:checked');if(!r)return false;
 if(r.classList.contains("oth")){var i=document.getElementById("i-"+(n==="rreason"?"reason":n));return !!(i&&i.value.trim());}return true;}
document.querySelector("#p-yes input").onchange=function(){st.declare="yes";render();};
document.querySelector("#p-no input").onchange=function(){st.declare="no";render();
 log("聲明「否」:偵測保單自動全剔、不可取消(新邏輯草案)","Declared No: detected policies auto-selected, cannot deselect (new logic draft)");};
function evAdd(){st.cards.push(mkCard(st.cards.length,document.getElementById("prefill").checked,false));render();
 log("[加] 名單 +1;舊剔選保留"+(st.declare==="no"?";「否」之下新卡自動剔選":";新卡"+(document.getElementById("prefill").checked?"已預填":"未剔選")+"(Q1)"),"[Add] +1; existing retained"+(st.declare==="no"?"; under No the new card auto-selects":"; new card "+(document.getElementById("prefill").checked?"pre-selected":"unselected")+" (Q1)"));}
function evDel(){var sys=st.cards.filter(function(c){return !c.manual;});if(!sys.length){log("[減] 無系統卡可移除","[Del] no detected card to remove");return;}
 var last=sys[sys.length-1];st.cards.splice(st.cards.indexOf(last),1);
 var left=st.cards.filter(function(c){return !c.manual;});
 if(left.length===1)left[0].sel=true;render();
 log("[減] 一張離開;其餘保留"+(left.length===1?";尾張自動剔選(R1)":""),"[Del] one left the list; others retained"+(left.length===1?"; last auto-selected (R1)":""));}
function evChg(){var c=st.cards.find(function(x){return !x.manual;});if(!c)return;c.amt=Math.round(c.amt*1.1);render();
 log("[改] 首張保費 +10%(模擬於頁外修改、重入時反映);總數重計","[Chg] 1st premium +10% (simulates off-page edit shown on re-entry); totals recalc");}
document.getElementById("ev-add").onclick=evAdd;
document.getElementById("ev-del").onclick=evDel;
document.getElementById("ev-chg").onclick=evChg;
document.getElementById("addp").onclick=function(){
 document.getElementById("f-nm").value="";document.getElementById("f-pd").value="";document.getElementById("f-amt").value="";
 document.getElementById("addmask").classList.add("show");document.getElementById("f-nm").focus();};
document.getElementById("f-cxl").onclick=function(){document.getElementById("addmask").classList.remove("show");};
document.getElementById("f-ok").onclick=function(){
 var nm=document.getElementById("f-nm").value.trim(),pd=document.getElementById("f-pd").value.trim(),amt=parseInt(document.getElementById("f-amt").value,10);
 document.getElementById("f-nm").style.borderColor=nm?"#DDD":"#C8102E";
 document.getElementById("f-pd").style.borderColor=pd?"#DDD":"#C8102E";
 document.getElementById("f-amt").style.borderColor=(amt>0)?"#DDD":"#C8102E";
 if(!nm||!pd||!(amt>0))return;
 st.cards.push({nm:nm,pz:pd,pe:pd,amt:amt,t:"rp",sel:true,manual:true,id:++st.seq});
 document.getElementById("addmask").classList.remove("show");render();
 log("[手動] 加入保單:"+nm+" / "+pd,"[Manual] policy added: "+nm+" / "+pd);};
function reset(n,selv,dec){st.cards=[];for(var i=0;i<n;i++)st.cards.push(mkCard(i,selv?selv[i]:true,false));st.declare=dec||"yes";
 reason("rreason",false);reason("rmk1",false);reason("rmk2",false);render();}
document.getElementById("ev-rst").onclick=function(){reset(2);document.getElementById("prefill").checked=false;log("已重設:2 張系統卡,聲明「是」","Reset: 2 detected cards, declared Yes");sel(-1);};
document.getElementById("genpdf").onclick=function(){
 var yes=st.declare==="yes",n=detected(),all=sysAll();var go,dz,de;
 if(yes&&detected()===1){if(filled("rreason")){go=true;dz="聲明是,除本張外無其他偵測,原因已填 — 放行。(N7)";de="Declared Yes with nothing else detected besides this application, and the concurrent reason completed. (N7)";}else{go=false;dz="除本張外無其他偵測,但「一併投保原因」未填 — 攔截。(N3)";de="Nothing else detected, but the concurrent reason is missing — blocked. (N3)";}}
 else if(yes&&all){if(filled("rreason")){go=true;dz="聲明「是」,已剔選全部偵測保單,一併投保原因已填妥。(N1)";de="Declared Yes with all detected policies selected and the concurrent reason completed. (N1)";}else{go=false;dz="「是」之下「一併投保原因」未填 — 請先填妥。分頁將標示未完成(!)。(N3)";de="The concurrent reason is missing under Yes — please complete it first. Tab will be flagged incomplete (!). (N3)";}}
 else if(yes){if(filled("rreason")&&filled("rmk1")){go=true;dz="聲明「是」,部分保單未剔選,但「一併投保原因」與 Remarks (1) 均已填妥。(N2)";de="Declared Yes with some policies unticked, and both the Reason and Remarks (1) are completed. (N2)";}
  else{go=false;dz="部分保單未剔選 — 請先填妥「一併投保原因」及 Remarks (1)。分頁將標示未完成(!)。(N3)";de="Some policies are unticked — please complete the Reason and Remarks (1) first. Tab will be flagged incomplete (!). (N3)";}}
 else{if(n===1){go=true;dz="聲明「否」,系統僅偵測到一張保單,已自動剔選,無需 Remarks。(N4)";de="Declared No with nothing else detected besides this application — good to go. (N4)";}
  else if(filled("rmk2")){go=true;dz="聲明「否」,偵測到的多張保單已全部自動剔選,Remarks (2) 已填妥。(N5)";de="Declared No — all detected policies auto-selected and Remarks (2) completed. (N5)";}
  else{go=false;dz="聲明「否」而偵測到多張保單 — 請先填妥 Remarks (2)。分頁將標示未完成(!)。(N6)";de="Declared No with multiple policies detected — please complete Remarks (2) first. Tab will be flagged incomplete (!). (N6)";}}
 modal(go?"pass":"block",go?"可以產生 PDF":"未能產生 PDF",go?"Ready to generate PDF":"Cannot generate PDF",dz,de);};
function gapM(code,z,e){modal("gapq","待答("+code+")","Open question ("+code+")",z,e);}
