<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SCB Concurrent — Scenario Demo</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@700;900&family=Noto+Sans+TC:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
:root{--ink:#1F2A28;--muted:#5C6B67;--line:#D8E2DE;--green-deep:#0B3B34;--green:#0F5A4E;--green-tint:#EAF2EF;
--amber:#B26F14;--amber-tint:#FBF1E1;--red:#B3362E;--red-tint:#F8E9E7;--ok:#2E7D4F;--ok-tint:#E7F2EA;
--paper:#FFFFFF;--panel:#F5F8F7;--serif:'Noto Serif TC',serif;--sans:'Noto Sans TC',sans-serif;--mono:'IBM Plex Mono',ui-monospace,monospace}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--sans);color:var(--ink);background:var(--paper);line-height:1.7;font-size:15px}
.wrap{max-width:980px;margin:0 auto;padding:0 22px}
section{padding:40px 0;border-bottom:1px solid var(--line)}
.eyebrow{font-family:var(--mono);font-size:12px;color:var(--green);letter-spacing:.14em;text-transform:uppercase}
h2{font-family:var(--serif);font-weight:700;font-size:clamp(20px,3vw,27px);margin:6px 0 14px;color:var(--green-deep)}
h3{font-family:var(--serif);font-weight:700;font-size:16.5px;margin:20px 0 8px;color:var(--green-deep)}
p{margin:0 0 12px;max-width:48em}
.tag{display:inline-block;font-family:var(--mono);font-size:11px;border:1.5px solid;border-radius:5px;padding:1px 7px;margin-right:6px}
.tag.ok{color:var(--ok);border-color:var(--ok)}.tag.tbc{color:var(--amber);border-color:var(--amber)}.tag.gap{color:var(--red);border-color:var(--red)}
table{border-collapse:collapse;width:100%;font-size:13px;margin:14px 0}
th{background:var(--green-deep);color:#fff;text-align:left;padding:7px 9px;font-weight:600}
td{border:1px solid var(--line);padding:6px 9px;vertical-align:top}
tr:nth-child(even) td{background:var(--panel)}
td.y{background:var(--amber-tint)!important}
/* scenario player */
.scgrp{margin:10px 0 4px;font-size:12.5px;color:var(--muted)}
.scbar{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:8px}
.scbar button{font-family:var(--mono);font-size:12.5px;padding:5px 10px;border-radius:7px;border:1.5px solid var(--line);background:#fff;cursor:pointer;color:var(--ink)}
.scbar button.gapb{border-style:dashed}
.scbar button[aria-pressed="true"]{background:var(--green);border-color:var(--green);color:#fff}
.sccard{border-radius:10px;background:var(--panel);padding:12px 16px;margin:10px 0 16px;font-size:13.5px;display:none}
.sccard b{color:var(--green-deep)}
.sccard .st{font-family:var(--mono);font-size:11.5px}
/* event bar */
.evbar{background:var(--green-deep);border-radius:12px;padding:10px 14px;max-width:880px;margin:12px auto 4px;display:flex;gap:9px;flex-wrap:wrap;align-items:center}
.evbar .lb{color:#9FC3BB;font-size:12px}
.evbar button{font-family:var(--sans);font-size:12.5px;padding:5px 11px;border-radius:8px;border:1.5px solid #3d6a61;background:transparent;color:#E7F0ED;cursor:pointer}
.evbar button:hover{background:rgba(255,255,255,.1)}
.evbar label{color:#CFE3DD;font-size:12px;display:flex;gap:6px;align-items:center;margin-left:auto}
.evlog{max-width:880px;margin:6px auto 0;font-size:12px;color:var(--muted);font-family:var(--mono);min-height:1.3em}
/* ipad */
.ipad{border:12px solid #16181a;border-radius:28px;background:#fff;max-width:880px;margin:14px auto;box-shadow:0 16px 36px rgba(0,0,0,.16);overflow:hidden;position:relative}
.ipad .top{display:flex;align-items:center;justify-content:space-between;padding:9px 16px;border-bottom:1px solid #E8E8E8;font-size:13px;color:#444}
.ipad .top .mid{font-weight:600}
.ipad .body{display:flex;min-height:480px}
.ipad .side{width:188px;border-right:1px solid #EEE;padding:10px 0;font-size:12px;color:#555;flex:none}
.ipad .side .it{padding:6px 13px;display:flex;justify-content:space-between;gap:6px}
.ipad .side .it .ck{color:#12A150;font-weight:700}
.ipad .side .it.cur{color:#C8102E;font-weight:700;background:#FDF1F2}
.ipad .side .sign{margin:14px 11px 0;background:#E4032E;color:#fff;text-align:center;border-radius:20px;padding:8px 6px;font-weight:700;font-size:12.5px;cursor:pointer;border:none;width:calc(100% - 22px);font-family:var(--sans)}
.ipad .cnt{flex:1;padding:18px 24px;min-width:0}
.ipad h4{font-size:18px;font-weight:700;color:#222;border-left:4px solid #00A99D;padding-left:9px;margin:0 0 12px}
.qlbl{font-size:13px;color:#333;margin:11px 0 7px}
.pill{display:inline-flex;align-items:center;gap:7px;border:1.5px solid #DDD;border-radius:8px;padding:7px 20px 7px 13px;margin-right:10px;cursor:pointer;font-size:13.5px;background:#FAFAFA;user-select:none}
.pill input{accent-color:#12A150}
.pill.on{border-color:#12A150;background:#F2FBF5}
.subq{display:none;margin:9px 0 3px}
.subq .qlbl{font-weight:600}
.pol{border:1.5px solid #DDD;border-radius:13px;padding:11px 15px;margin:9px 0;display:flex;gap:11px;align-items:flex-start;font-size:13px;position:relative}
.pol input{margin-top:3px;accent-color:#12A150;transform:scale(1.15)}
.pol .ref{position:absolute;top:7px;right:13px;font-size:10px;color:#999;font-family:var(--mono)}
.pol .nm{font-weight:700}
.pol .del{position:absolute;bottom:7px;right:13px;font-size:11.5px;color:#C8102E;background:none;border:none;cursor:pointer;font-family:var(--sans)}
.pol.sysp .del{display:none}
.hint{font-size:11px;color:#999;margin:3px 0 7px}
.addp{border:1.5px solid #DDD;background:#F5F5F5;border-radius:18px;padding:6px 16px;font-size:12.5px;cursor:pointer;float:right;font-family:var(--sans)}
.tot{clear:both;border:1px solid #E5E5E5;border-radius:12px;padding:11px 16px;margin:14px 0 6px;max-width:290px}
.tot .r{display:flex;justify-content:space-between;font-size:13px;padding:2px 0}
.tot .r b{font-family:var(--mono)}
.fx{text-align:center;font-size:11.5px;color:#8a6d3b;margin:9px 0 2px}
/* modal */
.mask{display:none;position:absolute;inset:0;background:rgba(0,0,0,.42);z-index:20;align-items:center;justify-content:center}
.mask.show{display:flex}
.mdl{background:#fff;border-radius:14px;max-width:400px;width:86%;padding:20px 22px;box-shadow:0 12px 30px rgba(0,0,0,.3)}
.mdl .ti{font-size:16px;font-weight:700;margin-bottom:8px}
.mdl.warn .ti{color:var(--amber)}.mdl.block .ti{color:#C8102E}.mdl.pass .ti{color:var(--ok)}.mdl.gapq .ti{color:var(--red)}
.mdl .ms{font-size:13.5px;color:#333;line-height:1.75;margin-bottom:16px}
.mdl .ok{display:block;width:100%;background:#E4032E;color:#fff;border:none;border-radius:20px;padding:9px;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--sans)}
.mdl.pass .ok{background:var(--ok)}
.fld{margin-bottom:11px}
.fld label{display:block;font-size:12.5px;color:#555;margin-bottom:4px}
.fld input{width:100%;border:1.5px solid #DDD;border-radius:8px;padding:8px 10px;font-size:13.5px;font-family:var(--sans)}
.fld input:focus{outline:none;border-color:#12A150}
.mdl .row2{display:flex;gap:10px;margin-top:4px}
.mdl .cancel{display:block;width:100%;background:#F0F0F0;color:#333;border:none;border-radius:20px;padding:9px;font-weight:700;font-size:14px;cursor:pointer;font-family:var(--sans)}
.treebox{border:1px solid var(--line);border-radius:12px;padding:10px;overflow-x:auto;background:#fff}
.treebox svg{min-width:720px}
#tv .nodeLabel,#tv .label{color:#1F2A28}
.tvbtn{font-family:var(--mono);font-size:12.5px;padding:5px 12px;border-radius:8px;border:1.5px solid var(--line);background:#fff;cursor:pointer;color:var(--ink)}
.tvbtn.on{background:var(--green-deep);border-color:var(--green-deep);color:#fff}
.lgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:10px;margin:12px 0}
.lgcard{background:var(--panel);border-radius:10px;padding:10px 13px}
.lgh{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;font-size:14px}
.used{font-family:var(--mono);font-size:10.5px;color:var(--muted)}
.lgr{display:flex;justify-content:space-between;gap:10px;font-size:12.5px;border-bottom:1px dashed var(--line);padding:3px 0}
.lgr:last-child{border-bottom:none}
.lgr .k{color:var(--muted);flex:none}
.old{color:var(--muted);font-family:var(--mono);font-size:11.5px}
.mcode{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px;overflow-x:auto;font-size:12px;font-family:var(--mono);line-height:1.6}
footer{padding:26px 0 46px;font-size:12px;color:var(--muted);font-family:var(--mono)}

.topbar{display:flex;justify-content:flex-end;padding:14px 0 0}
.lang-toggle{display:flex;border:1.5px solid var(--green-deep);border-radius:8px;overflow:hidden;background:#fff}
.lang-toggle button{font-family:var(--mono);font-size:12.5px;padding:5px 12px;border:none;background:#fff;cursor:pointer;color:var(--green-deep)}
.lang-toggle button.on{background:var(--green-deep);color:#fff}
body[data-lang="zh"] .en{display:none!important}
body[data-lang="en"] .zh{display:none!important}
</style>
</head>
